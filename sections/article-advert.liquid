    { "type": "color", "id": "box_border_color", "label": "Box border color", "default": "#000000" },
    {
      "type": "range",
      "id": "box_border_radius",
      "label": "Box border radius (px)",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "number_size",
