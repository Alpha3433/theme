    "store_faq_Lpd3PW": {
      "type": "store-faq",
      "blocks": {
        "faq_item_YYJUL8": {
          "type": "faq_item",
          "settings": {
            "question": "Will it hurt?",
            "answer": "<p>No zingers. PAP+ is peroxide-free and designed for sensitive teeth. Peroxide whitens by oxidising through the enamel — that's why strips sting. PAP+ breaks down stains without free radicals, so you get the lift without the sensitivity.</p>"
          }
        },
        "faq_item_xAnE8L": {
          "type": "faq_item",
          "settings": {
            "question": "Does it work on veneers or crowns?",
            "answer": "<p>No. Whitening only works on natural enamel, so PAP+ won't change the colour of veneers, crowns or fillings. If most of your smile is dental work, this isn't the product for you — we'd rather tell you now than refund you later.</p>"
          }
        },
        "faq_item_AUEi9b": {
          "type": "faq_item",
          "settings": {
            "question": "Is PAP safe?",
            "answer": "<p>PAP has been used in Australian cosmetic whitening for years. It's a peroxide-free pathway: it breaks down stains without the free radicals that cause peroxide sensitivity.</p>"
          }
        },
        "faq_item_Cm3eFx": {
          "type": "faq_item",
          "settings": {
            "question": "How long per session?",
            "answer": "<p>Ten minutes a day. The device is hands-free — load a ribbon of gel, bite down, and get on with getting ready. Rinse when the session's done.</p>"
          }
        },
        "faq_item_MhA9QW": {
          "type": "faq_item",
          "settings": {
            "question": "When do I see results?",
            "answer": "<p>Day 3: teeth feel cleaner and smoother. Day 7: first shade-card movement for most people. Day 14: someone comments on it. Day 30: side-by-side photo proof. Individual results vary — that's why every kit includes a shade card, so you can track yours.</p>"
          }
        },
        "faq_item_intfyb": {
          "type": "faq_item",
          "settings": {
            "question": "How do I cancel?",
            "answer": "<p>Two clicks from your account page. No lock-in, no emails, no phone calls. You can also skip a delivery, pause for a couple of cycles, or swap between the 2-pack and 4-pack.</p>"
          }
        }
      },
