{%- liquid
  assign path = request.path
  assign is_product_page = false
  assign title = ''

  if path contains 'pages'
    assign path = path | replace: '/pages', ''
    assign title = page.title
  endif

  if path contains 'products'
    assign is_product_page = true
    assign product_collection = product.collections.first
    assign title = product.title
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --cs-heading-letter-spacing: -0.3px;
    --cs-body-letter-spacing: 0px;
  }

  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} * {
    {%- if section.settings.section_font != blank -%}
      font-family: {{ section.settings.section_font.family }}, {{ section.settings.section_font.fallback_families }} !important;
    {%- endif -%}
    letter-spacing: var(--cs-body-letter-spacing);
  }

  #shopify-section-{{ section.id }} h1,
  #shopify-section-{{ section.id }} h2,
  #shopify-section-{{ section.id }} h3,
  #shopify-section-{{ section.id }} h4,
  #shopify-section-{{ section.id }} h5,
  #shopify-section-{{ section.id }} h6 {
    letter-spacing: var(--cs-heading-letter-spacing) !important;
  }

  #shopify-section-{{ section.id }} p,
  #shopify-section-{{ section.id }} span,
  #shopify-section-{{ section.id }} li,
  #shopify-section-{{ section.id }} a,
  #shopify-section-{{ section.id }} div {
    letter-spacing: var(--cs-body-letter-spacing);
  }

  #shopify-section-{{ section.id }} b,
  #shopify-section-{{ section.id }} strong,
  #shopify-section-{{ section.id }} [style*="font-weight:bold"],
  #shopify-section-{{ section.id }} [style*="font-weight: bold"],
  #shopify-section-{{ section.id }} .font-bold,
  #shopify-section-{{ section.id }} [class*="font-bold"] {
    font-weight: 700 !important;
  }

  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.section_background_color }}{% endif %};
  }

  /* Section-wide button styling */
  {%- liquid
    if section.settings.use_theme_colors
      assign button_color = settings.global_section_accent_1_color
    else
      assign button_color = section.settings.button_bg_color
    endif
    assign button_border = button_color | color_darken: 15
  -%}
  #shopify-section-{{ section.id }} .sidebar-product-link,
  #shopify-section-{{ section.id }} .content-button-link {
    background-color: {{ button_color }};
    color: {{ section.settings.button_text_color }};
    border-bottom: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color | default: button_border }};
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 700;
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
    text-decoration: none;
    display: block;
    text-align: center;
    transition: all 0.3s ease;
    letter-spacing: var(--cs-body-letter-spacing);
  }

  #shopify-section-{{ section.id }} .content-button-link:hover,
  #shopify-section-{{ section.id }} .sidebar-product-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }

  #shopify-section-{{ section.id }} .heading-block h1,
  #shopify-section-{{ section.id }} .heading-block h2,
  #shopify-section-{{ section.id }} .heading-block h3,
  #shopify-section-{{ section.id }} .heading-block h4,
  #shopify-section-{{ section.id }} .heading-block h5,
  #shopify-section-{{ section.id }} .heading-block h6 {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .breadcrumbs {
    margin-bottom: 5px;
    display: flex;
    align-items: center;
    gap: 7px;
    color: {% if section.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ section.settings.breadcrumb_color }}{% endif %};
  }

  #shopify-section-{{ section.id }} .breadcrumbs a {
    text-decoration: none;
    color: inherit;
  }

  {%- assign sidebar_w = section.settings.sidebar_width | default: 35 -%}
  {%- assign content_w = 100 | minus: sidebar_w -%}
  {%- assign sticky_top = section.settings.sidebar_sticky_top | default: 20 -%}

  #shopify-section-{{ section.id }} .section-main {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ section.settings.horizontal_padding }}px;
  }

  #shopify-section-{{ section.id }} .section-main > .breadcrumbs {
    margin-bottom: 10px;
  }

  #shopify-section-{{ section.id }} .section-layout {
    display: grid;
    grid-template-columns: {{ content_w }}fr {{ sidebar_w }}fr;
    gap: {{ section.settings.content_gap }}px;
    align-items: start;
    position: relative;
  }

  #shopify-section-{{ section.id }} .section-content {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .section-sidebar {
    min-width: 0;
  }

  /* Target both the block class and any potential wrapper Shopify might add */
  #shopify-section-{{ section.id }} .section-layout > *:nth-child(2),
  #shopify-section-{{ section.id }} .section-sidebar {
    {% if section.settings.sidebar_sticky %}
      position: -webkit-sticky !important;
      position: sticky !important;
      top: {{ sticky_top }}px !important;
      align-self: start !important;
      z-index: 10;
    {% endif %}
  }

  /* Target any potentially nested containers if Shopify wraps blocks */
  #shopify-section-{{ section.id }} [id^="shopify-block-"] {
    height: 100%;
  }

  #shopify-section-{{ section.id }} .section-sidebar-wrapper {
    height: 100%;
  }

  /* Amazon Reviews block - spans full width below content and sidebar */
  #shopify-section-{{ section.id }} .cs-amazon-reviews-wrapper {
    grid-column: 1 / -1;
    margin-top: 20px;
  }

  @media screen and (max-width: 1105px) {
    #shopify-section-{{ section.id }} .section-layout {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    #shopify-section-{{ section.id }} .section-sidebar,
    #shopify-section-{{ section.id }} .section-sidebar[style] {
      position: static !important;
      top: auto !important;
      max-height: none !important;
      overflow-y: visible !important;
      align-self: auto !important;
    }
  }

  /* Global image styling */
  #shopify-section-{{ section.id }} img {
    max-width: 100%;
    height: auto;
  }

  #shopify-section-{{ section.id }} .image-container img,
  #shopify-section-{{ section.id }} .image-block img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .section-main {
      padding: 0 {{ section.settings.mobile_horizontal_padding }}px;
      gap: 0;
    }

    #shopify-section-{{ section.id }} .sidebar-product-link,
    #shopify-section-{{ section.id }} .content-button-link {
      font-size: {{ section.settings.button_font_size | times: 0.9 | round }}px;
    }

    /* Ensure all images are responsive on mobile */
    #shopify-section-{{ section.id }} img {
      max-width: 100%;
      height: auto !important;
      width: auto;
    }

    #shopify-section-{{ section.id }} .image-container,
    #shopify-section-{{ section.id }} .image-block {
      width: 100%;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .image-container img,
    #shopify-section-{{ section.id }} .image-block img {
      width: 100%;
      height: auto !important;
      object-fit: contain;
    }

    #shopify-section-{{ section.id }} .sidebar-featured-product .image-container img {
      width: 100%;
      height: auto !important;
    }
  }
{%- endstyle -%}

<div class="inner-con page-width">
  <div class="section-main">
    {%- if section.settings.show_breadcrumb -%}
      <div class="breadcrumbs">
        <a href="{{ routes.root_url }}" class="breadcrumb-link">
          {{ section.settings.breadcrumb_home_text }}
        </a>

        {%- if section.settings.breadcrumb_second_text != blank -%}
          <span class="breadcrumb-separator">{{ section.settings.breadcrumb_separator }}</span>
          {%- if section.settings.breadcrumb_second_url != blank -%}
            <a href="{{ section.settings.breadcrumb_second_url }}" class="breadcrumb-link">
              {{ section.settings.breadcrumb_second_text }}
            </a>
          {%- else -%}
            <span class="breadcrumb-link">{{ section.settings.breadcrumb_second_text }}</span>
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.breadcrumb_current_text != blank -%}
          <span class="breadcrumb-separator">{{ section.settings.breadcrumb_separator }}</span>
          <span class="breadcrumb-link last-link">{{ section.settings.breadcrumb_current_text }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size == 0 -%}
      <div style="padding: 60px 20px; text-align: center; background: #f9f9f9; border: 2px dashed #ddd; border-radius: 8px; margin: 20px 0;">
        <p style="font-size: 18px; color: #666; margin: 0 0 10px 0;">This section is empty!</p>
        <p style="font-size: 14px; color: #999; margin: 0;">
          Add a "CS Content" block for the main area and optionally a "CS Sidebar" block.
        </p>
      </div>
    {%- endif -%}

    <div class="section-layout">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Content Sidebar v2",
  "class": "cstm-content-sidebar-v2",
  "blocks": [
    { "type": "cs-header-banner" },
    { "type": "sidebar-title" },
    { "type": "cs-content" },
    { "type": "cs-sidebar" },
